    .btn-teal:hover { background: linear-gradient(135deg, rgba(45,212,191,.32), rgba(45,212,191,.15)); box-shadow: 0 0 20px rgba(45,212,191,.25); }
    .btn-blue {
      background: linear-gradient(135deg, rgba(96,165,250,.2), rgba(96,165,250,.08));
      border-color: rgba(96,165,250,.4);

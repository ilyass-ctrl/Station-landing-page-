    .logo-text { line-height: 1.15; }
    .logo-text strong { display: block; font-size: 15px; font-weight: 800; letter-spacing: -.3px; }
    .logo-text span   { display: block; font-size: 11.5px; font-weight: 600; color: var(--muted); }

    nav { display: flex; align-items: center; gap: 2px; }

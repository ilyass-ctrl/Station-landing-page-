    .stat-num span { color: var(--teal); }
    .stat-label { font-size: 12px; font-weight: 600; color: var(--muted); margin-top: 2px; }

    /* ─── SECTION HEADERS ─── */
    section { padding: 70px 0; }
    .section-tag {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 5px 14px; border-radius: 999px;
      font-size: 11.5px; font-weight: 700; letter-spacing: .5px; text-transform: uppercase;
      border: 1px solid rgba(45,212,191,.3);
      background: rgba(45,212,191,.08);
      color: var(--teal);
      margin-bottom: 14px;
    }
    .section-h {
      font-size: clamp(26px, 3vw, 38px);
      font-weight: 900;
      letter-spacing: -1px;
      margin-bottom: 10px;
      line-height: 1.1;
    }
    .section-sub {
      font-size: 16px; color: var(--muted); line-height: 1.7;
      max-width: 640px; font-weight: 500;
      margin-bottom: 36px;
    }
    .section-head-row {
      display: flex; align-items: flex-end; justify-content: space-between;
      gap: 20px; flex-wrap: wrap;
      margin-bottom: 36px;
    }

    /* ─── SALE BADGE ─── */
    .sale-badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 8px;
      font-size: 11px; font-weight: 800; letter-spacing: .3px; text-transform: uppercase;
      background: linear-gradient(135deg, rgba(251,146,60,.25), rgba(251,146,60,.12));
      border: 1px solid rgba(251,146,60,.4);
      color: var(--orange);
    }
    .sale-badge-red {
      background: linear-gradient(135deg, rgba(248,113,113,.25), rgba(248,113,113,.1));
      border-color: rgba(248,113,113,.4);
      color: var(--red);
    }
    .sale-badge-gold {
      background: linear-gradient(135deg, rgba(251,191,36,.2), rgba(251,191,36,.08));
      border-color: rgba(251,191,36,.4);
      color: var(--gold);
    }

    /* ─── PRODUCT CARDS ─── */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .product-card {
      border-radius: var(--r);
      border: 1px solid var(--border);
      background: var(--card);
      overflow: hidden;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      display: flex; flex-direction: column;
    }
    .product-card:hover {
      transform: translateY(-4px);
      border-color: rgba(45,212,191,.25);
      box-shadow: 0 24px 60px rgba(0,0,0,.45), 0 0 0 1px rgba(45,212,191,.1);
    }
    .product-card.featured {
      border-color: rgba(45,212,191,.3);
      background: linear-gradient(180deg, rgba(45,212,191,.06), rgba(45,212,191,.02));
    }
    .product-card.featured:hover {
      border-color: rgba(45,212,191,.5);
      box-shadow: 0 24px 60px rgba(0,0,0,.45), 0 0 30px rgba(45,212,191,.18);
    }

    .product-img {
      width: 100%; aspect-ratio: 16/9;
      overflow: hidden; position: relative;
      background: linear-gradient(135deg, #0d1428, #111827);
    }
    .product-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform .4s ease;
    }
    .product-card:hover .product-img img { transform: scale(1.06); }
    .product-img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 40%, rgba(5,8,16,.7) 100%);
    }
    .product-badges {
      position: absolute; top: 12px; left: 12px;
      display: flex; gap: 6px; flex-wrap: wrap;
    }

    .product-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
    .product-name {
      font-size: 17px; font-weight: 800; line-height: 1.25;
      letter-spacing: -.3px;
    }
    .product-desc { font-size: 13.5px; color: var(--muted); line-height: 1.6; font-weight: 500; }

    .price-block { margin-top: 4px; }
    .price-row { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 6px; }
    .price-size { font-size: 12px; font-weight: 700; color: var(--muted2); min-width: 60px; }
    .price-was { font-size: 13px; color: var(--muted2); text-decoration: line-through; font-weight: 600; }
    .price-now { font-size: 22px; font-weight: 900; color: var(--teal); letter-spacing: -1px; }
    .price-now.accent { color: var(--orange); }
    .price-unit { font-size: 12px; color: var(--muted); font-weight: 600; }

      aspect-ratio: unset;
      flex-shrink: 0;
      border-radius: 0;
    }
    .product-card.wide .product-img img { height: 100%; }

    /* ─── SALE SECTION ─── */
    .sale-banner {
      border-radius: var(--r);
      overflow: hidden;
      position: relative;
      background: linear-gradient(135deg, rgba(251,146,60,.12) 0%, rgba(248,113,113,.1) 50%, rgba(96,165,250,.1) 100%);

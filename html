    .chip-green { border-color: rgba(74,222,128,.3); background: rgba(74,222,128,.06); color: var(--green); }
    .chip-teal  { border-color: rgba(45,212,191,.3); background: rgba(45,212,191,.06); color: var(--teal); }
    .chip-blue  { border-color: rgba(96,165,250,.3); background: rgba(96,165,250,.06); color: var(--blue); }
    .live-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--green);
      animation: pulse-dot 2s ease-in-out infinite;
      flex-shrink: 0;
    }

    /* ─── HEADER / NAV ─── */

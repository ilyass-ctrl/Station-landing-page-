      font-size: 12.5px; font-weight: 600; color: var(--muted);
    }
    .trust-item .icon { font-size: 16px; }

    /* Hero visual side */
    .hero-visual {
      position: relative;
    }
    .hero-card-main {
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid var(--border2);
      box-shadow: var(--shadow);
      position: relative;
      background: var(--bg2);
      aspect-ratio: 4/3;
    }
    .hero-card-main img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform .6s ease;
    }
    .hero-card-main:hover img { transform: scale(1.04); }
    .hero-card-main .overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(5,8,16,.85) 0%, transparent 55%);
    }
    .hero-card-main .card-label {
      position: absolute; bottom: 18px; left: 18px; right: 18px;
    }
    .hero-card-main .card-label strong {
      display: block; font-size: 18px; font-weight: 800; margin-bottom: 4px;
    }
    .hero-card-main .card-label p {
      font-size: 13px; color: rgba(238,243,255,.75); font-weight: 500;
    }
    .hero-floating {
      position: absolute;
      background: rgba(8,13,26,.92);
      backdrop-filter: blur(16px);
      border: 1px solid var(--border2);
      border-radius: 16px;
      padding: 12px 14px;
      box-shadow: var(--shadow2);
    }
    .hero-float-1 {
      top: -16px; right: -16px;
      animation: float 4s ease-in-out infinite;
    }
    .hero-float-2 {
      bottom: -16px; left: -16px;
      animation: float 5s ease-in-out infinite .8s;
    }
    .float-label { font-size: 11px; font-weight: 600; color: var(--muted); }
    .float-value { font-size: 20px; font-weight: 900; color: var(--teal); letter-spacing: -1px; margin: 2px 0; }
    .float-sub   { font-size: 11px; font-weight: 600; color: var(--muted2); }

    /* ─── STATS STRIP ─── */
    .stats-strip {
      padding: 30px 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--bg1);

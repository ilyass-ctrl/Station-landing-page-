    .btn-blue:hover { background: linear-gradient(135deg, rgba(96,165,250,.3), rgba(96,165,250,.12)); }
    .btn-orange {
      background: linear-gradient(135deg, rgba(251,146,60,.22), rgba(251,146,60,.1));
      border-color: rgba(251,146,60,.4);
      color: #fed7aa;
    }
    .btn-orange:hover { background: linear-gradient(135deg, rgba(251,146,60,.35), rgba(251,146,60,.15)); }
    .btn-lg { padding: 14px 24px; font-size: 15px; border-radius: 14px; }
    .btn-xl { padding: 16px 30px; font-size: 16px; font-weight: 800; border-radius: 16px; }

    /* ─── HERO ─── */
    .hero {
      padding: 60px 0 40px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 900px 600px at -5% -10%, rgba(45,212,191,.13), transparent 55%),
        radial-gradient(ellipse 900px 600px at 105% -10%, rgba(96,165,250,.12), transparent 55%),
        radial-gradient(ellipse 600px 400px at 50% 100%, rgba(96,165,250,.07), transparent 60%);
      pointer-events: none;
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 50px;
      align-items: center;
      position: relative;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 14px; border-radius: 999px;
      background: rgba(45,212,191,.1);
      border: 1px solid rgba(45,212,191,.3);
      font-size: 12px; font-weight: 700;
      color: var(--teal);
      margin-bottom: 20px;
    }
    .hero h1 {
      font-size: clamp(36px, 4vw, 58px);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -1.5px;
      margin-bottom: 20px;
    }
    .hero h1 .gradient-text {
      background: linear-gradient(135deg, var(--teal) 0%, var(--blue) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-desc {
      font-size: 17px;
      color: rgba(238,243,255,.78);
      line-height: 1.7;
      margin-bottom: 28px;
      max-width: 520px;
      font-weight: 500;
    }
    .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 30px; }
    .hero-trust {
      display: flex; gap: 18px; flex-wrap: wrap;
      padding-top: 20px;

      border: 1px solid rgba(74,222,128,.25);
      color: var(--green);
    }

    .best-for { margin-top: 12px; }
    .best-for-title { font-size: 11.5px; font-weight: 700; color: var(--muted2); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; }
    .best-for ul { list-style: none; display: grid; gap: 6px; }
    .best-for li {
      display: flex; gap: 8px; align-items: flex-start;
      font-size: 12.5px; font-weight: 600; color: rgba(238,243,255,.82); line-height: 1.4;
    }
    .best-for li .ck {
